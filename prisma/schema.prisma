// ============================================================
// SwapTest — Database Schema (Prisma)
// ============================================================
// Run after changes:
//   npx prisma db push    (dev — applies directly)
//   npx prisma migrate dev (prod — creates migration file)
//   npx prisma generate    (regenerates the client)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Users ─────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  phone        String
  password     String   // bcrypt hash
  tokenVersion Int      @default(0) // bumped on password reset to invalidate all existing JWTs
  registrationPaidAt DateTime? // set once the one-time £1 registration fee is paid; gates listing creation
  pushToken    String?  // APNs device token for push notifications
  pushPlatform String?  // "ios" or "android"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  listings        Listing[]
  matchesAsEarlier Match[] @relation("EarlierUser")
  matchesAsLater   Match[] @relation("LaterUser")
  payments        Payment[]

  @@index([email])
}

// ── Listings ──────────────────────────────────────────────

enum ListingType {
  EARLIER  // user wants an earlier date
  LATER    // user wants a later date (willing to swap for later)
}

enum TestType {
  WEEKDAY          // weekday test (£62)
  EVENING_WEEKEND  // evening, weekend or bank holiday test (£75)
}

enum ListingStatus {
  AVAILABLE  // open for matching
  LOCKED     // someone selected this, pending confirmation
  MATCHED    // fully matched and paid
  EXPIRED    // match timed out, back in pool
  CANCELLED  // user cancelled their listing
}

model Listing {
  id                String        @id @default(cuid())
  userId            String
  type              ListingType
  centre            String        // exact DVSA test centre name
  testType          TestType      @default(WEEKDAY) // must match for a swap (DVSA rule)
  originalCentre    String?       // if they swapped before, the centre they can move back to
  currentDate       DateTime      // user's existing test date
  currentTime       String        // e.g. "09:30"
  status            ListingStatus @default(AVAILABLE)
  lockedByMatchId   String?       // which match locked this listing
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user              User          @relation(fields: [userId], references: [id])
  matchesAsEarlier  Match[]       @relation("EarlierListing")
  matchesAsLater    Match[]       @relation("LaterListing")

  @@index([centre, type, status])    // primary matching query
  @@index([userId])
  @@index([status])
}

// ── Matches ───────────────────────────────────────────────

enum MatchStatus {
  PENDING      // matched; awaiting both consents + the earlier-seeker's £8 payment
  COMPLETED    // both consented and earlier paid — contact details exchanged
  EXPIRED      // not completed before payDeadline
  DECLINED     // a party declined
  CANCELLED    // admin or system cancelled
}

model Match {
  id                String      @id @default(cuid())

  earlierUserId     String
  laterUserId       String
  earlierListingId  String
  laterListingId    String
  initiatedByUserId String      // who clicked "Select"

  status            MatchStatus @default(PENDING)

  // Consent — both parties must accept the data-sharing disclaimer before contact exchange
  earlierConsentAt  DateTime?
  laterConsentAt    DateTime?

  // Payment — only the earlier-date seeker pays the £8 swap fee
  earlierPaid       Boolean     @default(false)
  earlierPaymentId  String?     // Stripe PaymentIntent ID

  // Single completion deadline (absolute timestamp)
  payDeadline       DateTime?

  // Metadata
  createdAt         DateTime    @default(now())
  completedAt       DateTime?
  expiredAt         DateTime?

  // Relations
  earlierUser       User        @relation("EarlierUser", fields: [earlierUserId], references: [id])
  laterUser         User        @relation("LaterUser", fields: [laterUserId], references: [id])
  earlierListing    Listing     @relation("EarlierListing", fields: [earlierListingId], references: [id])
  laterListing      Listing     @relation("LaterListing", fields: [laterListingId], references: [id])
  payments          Payment[]

  @@index([status])
  @@index([payDeadline])
}

// ── Payments ──────────────────────────────────────────────

enum PaymentStatus {
  PENDING
  SUCCEEDED
  REFUNDED
  FAILED
}

model Payment {
  id                String        @id @default(cuid())
  purpose           String        @default("swap") // "swap" | "registration"
  matchId           String?       // null for registration payments
  userId            String
  amountPence       Int           // e.g. 100 = £1.00 registration, 800 = £8.00 swap
  stripeSessionId   String?       @unique // Stripe Checkout Session ID
  stripePaymentId   String?       // Stripe PaymentIntent ID
  status            PaymentStatus @default(PENDING)
  refundedAt        DateTime?
  createdAt         DateTime      @default(now())

  match             Match?        @relation(fields: [matchId], references: [id])
  user              User          @relation(fields: [userId], references: [id])

  @@index([stripeSessionId])
  @@index([matchId])
}
