// ============================================================
// SwapTest — Database Schema (Prisma)
// ============================================================
// Run after changes:
//   npx prisma db push    (dev — applies directly)
//   npx prisma migrate dev (prod — creates migration file)
//   npx prisma generate    (regenerates the client)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Users ─────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  phone        String
  password     String   // bcrypt hash
  tokenVersion Int      @default(0) // bumped on password reset to invalidate all existing JWTs
  pushToken    String?  // APNs device token for push notifications
  pushPlatform String?  // "ios" or "android"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  listings        Listing[]
  matchesAsEarlier Match[] @relation("EarlierUser")
  matchesAsLater   Match[] @relation("LaterUser")
  payments        Payment[]

  @@index([email])
}

// ── Listings ──────────────────────────────────────────────

enum ListingType {
  EARLIER  // user wants an earlier date
  LATER    // user wants a later date (willing to swap for later)
}

enum ListingStatus {
  AVAILABLE  // open for matching
  LOCKED     // someone selected this, pending confirmation
  MATCHED    // fully matched and paid
  EXPIRED    // match timed out, back in pool
  CANCELLED  // user cancelled their listing
}

model Listing {
  id                String        @id @default(cuid())
  userId            String
  type              ListingType
  centre            String        // exact DVSA test centre name
  currentDate       DateTime      // user's existing test date
  currentTime       String        // e.g. "09:30"
  preferredDateFrom DateTime      // earliest acceptable swap date
  preferredDateTo   DateTime?     // latest acceptable swap date (optional)
  status            ListingStatus @default(AVAILABLE)
  lockedByMatchId   String?       // which match locked this listing
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user              User          @relation(fields: [userId], references: [id])
  matchesAsEarlier  Match[]       @relation("EarlierListing")
  matchesAsLater    Match[]       @relation("LaterListing")

  @@index([centre, type, status])    // primary matching query
  @@index([userId])
  @@index([status])
}

// ── Matches ───────────────────────────────────────────────

enum MatchStatus {
  PENDING_LATER_PAY    // waiting for "later" person to agree + pay
  PENDING_EARLIER_PAY  // "later" paid, waiting for "earlier" person
  COMPLETED            // both paid, contact details exchanged
  EXPIRED_TIMER1       // "later" person didn't pay in time
  EXPIRED_TIMER2       // "earlier" person didn't pay in time (refund "later")
  DECLINED             // "later" person declined
  CANCELLED            // admin or system cancelled
}

model Match {
  id                String      @id @default(cuid())

  earlierUserId     String
  laterUserId       String
  earlierListingId  String
  laterListingId    String
  initiatedByUserId String      // who clicked "Select" — drives messaging and payment order

  status            MatchStatus @default(PENDING_LATER_PAY)

  // Payment tracking
  laterPaid         Boolean     @default(false)
  earlierPaid       Boolean     @default(false)
  laterPaymentId    String?     // Stripe PaymentIntent ID
  earlierPaymentId  String?     // Stripe PaymentIntent ID

  // Timeout deadlines (absolute timestamps)
  laterPayDeadline   DateTime   // when timer1 expires
  earlierPayDeadline DateTime?  // set after laterPaid=true

  // Metadata
  createdAt         DateTime    @default(now())
  completedAt       DateTime?
  expiredAt         DateTime?

  // Relations
  earlierUser       User        @relation("EarlierUser", fields: [earlierUserId], references: [id])
  laterUser         User        @relation("LaterUser", fields: [laterUserId], references: [id])
  earlierListing    Listing     @relation("EarlierListing", fields: [earlierListingId], references: [id])
  laterListing      Listing     @relation("LaterListing", fields: [laterListingId], references: [id])
  payments          Payment[]

  @@index([status])
  @@index([laterPayDeadline])
  @@index([earlierPayDeadline])
}

// ── Payments ──────────────────────────────────────────────

enum PaymentStatus {
  PENDING
  SUCCEEDED
  REFUNDED
  FAILED
}

model Payment {
  id                String        @id @default(cuid())
  matchId           String
  userId            String
  amountPence       Int           // 300 = £3.00
  stripeSessionId   String?       @unique // Stripe Checkout Session ID
  stripePaymentId   String?       // Stripe PaymentIntent ID
  status            PaymentStatus @default(PENDING)
  refundedAt        DateTime?
  createdAt         DateTime      @default(now())

  match             Match         @relation(fields: [matchId], references: [id])
  user              User          @relation(fields: [userId], references: [id])

  @@index([stripeSessionId])
  @@index([matchId])
}
