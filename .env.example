# ============================================================
# SwapTest — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# ============================================================

# ── Database (Neon / Supabase PostgreSQL) ──────────────────
DATABASE_URL="postgresql://user:password@host:5432/swaptest?sslmode=require"

# ── Authentication ─────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET="your-jwt-secret-here-min-32-chars"

# ── Stripe ─────────────────────────────────────────────────
# Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Dashboard → Developers → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET="whsec_..."
# Price ID for the £3 platform fee (create in Stripe Dashboard → Products)
STRIPE_PRICE_ID="price_..."

# ── Resend (Email) ─────────────────────────────────────────
# Dashboard: https://resend.com/api-keys
RESEND_API_KEY="re_..."
# The "from" address (must be verified domain in Resend)
EMAIL_FROM="SwapTest <noreply@swaptest.co.uk>"
# Inbox that contact-form submissions are sent to (defaults to hello@swaptest.co.uk)
CONTACT_TO_EMAIL="hello@swaptest.co.uk"

# ── Upstash (Rate Limiting + Cron) ─────────────────────────
# Dashboard: https://console.upstash.com
UPSTASH_REDIS_REST_URL="https://..."
UPSTASH_REDIS_REST_TOKEN="..."
QSTASH_TOKEN="..."
# The base URL of your deployed app (used for QStash callbacks)
QSTASH_CURRENT_SIGNING_KEY="sig_..."
QSTASH_NEXT_SIGNING_KEY="sig_..."

# ── App Config ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Master payments switch. Only when set to exactly "true" are the £1 registration
# and £8 swap fees charged via Stripe. Anything else (or unset) = free mode:
# registration and swaps complete without any charge, and the UI shows "free".
NEXT_PUBLIC_PAYMENTS_ENABLED="false"
# One-time registration fee (pence). 100 = £1.00
REGISTRATION_FEE_PENCE=100
# Swap fee paid by the earlier-date seeker only (pence). 800 = £8.00
SWAP_FEE_PENCE=800
# Hours a match stays open for both consents + the earlier-seeker's payment
SWAP_DEADLINE_HOURS=24

# ── Cron Secret (protect the /api/cron/* endpoints) ────────
# Generate with: openssl rand -hex 32
CRON_SECRET="your-cron-secret-here"
